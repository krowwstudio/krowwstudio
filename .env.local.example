# Resend (preferred — inbox delivery guaranteed, free 3k emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Gmail SMTP (fallback for local dev only — may land in spam in production)
GMAIL_USER=krowwstudio@gmail.com
